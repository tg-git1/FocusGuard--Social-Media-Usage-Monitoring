<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/warm_cream"
    android:padding="16dp"
    android:importantForAccessibility="no">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select Productive Apps"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Any app NOT selected here will be treated as a distraction."
            android:textSize="14sp"
            android:textColor="#757575"
            android:layout_marginBottom="20dp"/>

        <LinearLayout
            android:id="@+id/llAppList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp"/>

        <Button
            android:id="@+id/btnSaveApps"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Save Selection"
            android:backgroundTint="@color/sage_green"
            android:textColor="@color/white"
            app:cornerRadius="12dp"/>

    </LinearLayout>
</ScrollView>